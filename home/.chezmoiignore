# Platform use cases (see README "Target Use Cases"):
#   macOS   — full desktop dev surface
#   Windows — daily use / partial dev; minimal surface, no fish / fonts / Claude
#   Linux   — headless WSL or VM; no GUI-only items
{{- if ne .chezmoi.os "windows" }}
Documents/PowerShell
00_install_packages.ps1
{{- end }}
{{- if eq .chezmoi.os "windows" }}
.config/fish
.config/git/ignore
00_install_packages.sh
{{- end }}

# Claude Code — disabled via useClaude=false or on Windows
{{- if not .useClaude }}
.claude
.config/ccstatusline
.config/fish/functions/glm.fish
{{- end }}

# fish conf.d — machine-specific, managed outside chezmoi
.config/fish/conf.d

# fish functions that are macOS-only
{{- if ne .chezmoi.os "darwin" }}
.config/fish/functions/tailscale.fish
.config/fish/functions/ts.fish
{{- end }}

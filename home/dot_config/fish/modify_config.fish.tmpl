#!/bin/bash
# Uses bash (not fish) because chezmoi runs modify scripts before fish is installed.
# Replaces the chezmoi-managed block in config.fish, preserving everything else.
set -e

BEGIN_MARKER='# BEGIN chezmoi managed'
END_MARKER='# END chezmoi managed'

existing=$(cat)

# Build the managed block
managed=()
managed+=("$BEGIN_MARKER")
{{- if eq .chezmoi.os "darwin" }}
managed+=('if test -d /opt/homebrew')
managed+=('    # Homebrew is installed on MacOS')
managed+=('    /opt/homebrew/bin/brew shellenv | source')
managed+=('end')
managed+=('')
{{- end }}
managed+=('fish_add_path $HOME/.local/bin')
managed+=('')
managed+=('starship init fish | source')
managed+=('zoxide init fish | source')
managed+=('abbr -a cz --position command chezmoi')
managed+=('abbr -a ts --position command tailscale')
managed+=("$END_MARKER")

# Strip existing managed block and output
in_block=0
while IFS= read -r line; do
    if [ "$line" = "$BEGIN_MARKER" ]; then
        in_block=1
    elif [ "$line" = "$END_MARKER" ]; then
        in_block=0
    elif [ "$in_block" -eq 0 ]; then
        printf '%s\n' "$line"
    fi
done <<< "$existing"

# Append managed block
for line in "${managed[@]}"; do
    printf '%s\n' "$line"
done
